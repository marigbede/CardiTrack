# Production Environment Configuration Example
# Copy this file to prod.tfvars and fill in sensitive/specific values
# terraform apply -var-file="environments/prod.tfvars"

environment  = "prod"
region       = "europe-west2"
project_id   = "carditrack-490120"
project_name = "carditrack"

# Database Credentials
# Password is read from GCP Secret Manager: carditrack-prod-db-password
db_admin_username = "carditrackadmin"

# Container Images (REQUIRED - set to your Artifact Registry images)
api_container_image = "europe-west2-docker.pkg.dev/your-project/carditrack/api:latest"
web_container_image = "europe-west2-docker.pkg.dev/your-project/carditrack/web:latest"

# Custom Domains (WAF + CDN + GCLB enabled when set)
api_custom_domain = "api.carditrack.com"
web_custom_domain = "app.carditrack.com"

# Cloud Run
cloud_run_cpu    = "2"
cloud_run_memory = "1Gi"

# Cloud SQL
cloud_sql_tier                = "db-custom-2-7680"  # 2 vCPU, 7.5 GB RAM
cloud_sql_disk_size_gb        = 100
cloud_sql_ha_enabled          = true   # Regional HA for production
cloud_sql_deletion_protection = true   # Prevent accidental deletion

# Storage
storage_location = "EU"
storage_class    = "STANDARD"

# Pub/Sub
enable_pubsub = true

# HIPAA Compliance
enable_hipaa_compliance = true
audit_retention_days    = 90  # HIPAA requirement

# Labels
additional_labels = {
  cost_center = "engineering"
  owner       = "production_team"
  compliance  = "hipaa"
}
