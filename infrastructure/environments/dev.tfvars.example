# Development Environment Configuration Example
# Copy this file to dev.tfvars and fill in sensitive values
# terraform apply -var-file="environments/dev.tfvars"

environment  = "dev"
location     = "eastus"
project_name = "carditrack"

# SQL Server Credentials (REQUIRED - fill these in)
sql_admin_username = "sqladmin"
sql_admin_password = "CHANGE_ME_STRONG_PASSWORD_123!"

# App Service
app_service_sku       = "B1"
app_service_always_on = false

# SQL Database
sql_database_sku         = "Basic"
sql_database_max_size_gb = 2

# Storage
storage_replication_type                 = "LRS"
storage_enable_infrastructure_encryption = false

# Key Vault
key_vault_sku                        = "standard"
key_vault_soft_delete_retention_days = 7
key_vault_purge_protection_enabled   = false

# Application Insights
app_insights_retention_days = 30

# SignalR
enable_signalr = false

# HIPAA Compliance
enable_hipaa_compliance  = false
sql_audit_retention_days = 30

# Additional Tags
additional_tags = {
  CostCenter = "Development"
  Owner      = "DevTeam"
}
