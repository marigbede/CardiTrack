<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardiTrack.Mobile.ForgotPasswordPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource White}">

    <Grid RowDefinitions="Auto,*">

        <!-- ════════════════════════════════════════
             GRADIENT HEADER
             ════════════════════════════════════════ -->
        <Grid Grid.Row="0" HeightRequest="175" HorizontalOptions="Fill">
            <Image Source="gradient_auth_header.svg"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill" />

            <VerticalStackLayout Padding="20,48,20,0" VerticalOptions="Start">
                <Label Text="Forgot Password?"
                       Style="{StaticResource Heading1White}" />
            </VerticalStackLayout>
        </Grid>

        <!-- ════════════════════════════════════════
             WHITE CARD — VERIFY CODE
             ════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Margin="0,-30,0,0"
                Padding="20,0,20,36">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0"
                                 VerticalOptions="Center"
                                 Padding="0,40,0,0">

                <!-- Title -->
                <Label Text="Verify Code"
                       Style="{StaticResource Heading2}"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,8"/>

                <!-- Description -->
                <Label Text="We sent a 6 digit code to your email. Enter it below"
                       Style="{StaticResource Body2}"
                       TextColor="{StaticResource HeadingText}"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,24"/>

                <!-- 6-digit code entry boxes -->
                <HorizontalStackLayout x:Name="CodePanel"
                                       HorizontalOptions="Center"
                                       Spacing="12">
                    <Border x:Name="CodeBorder0" Style="{StaticResource AuthEntryBorder}"
                            WidthRequest="51" HeightRequest="56"
                            Padding="0">
                        <Entry x:Name="Code0" Style="{StaticResource AuthEntry}"
                               MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="22" FontAttributes="Bold"
                               TextChanged="OnCodeDigitChanged"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Border x:Name="CodeBorder1" Style="{StaticResource AuthEntryBorder}"
                            WidthRequest="51" HeightRequest="56"
                            Padding="0">
                        <Entry x:Name="Code1" Style="{StaticResource AuthEntry}"
                               MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="22" FontAttributes="Bold"
                               TextChanged="OnCodeDigitChanged"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Border x:Name="CodeBorder2" Style="{StaticResource AuthEntryBorder}"
                            WidthRequest="51" HeightRequest="56"
                            Padding="0">
                        <Entry x:Name="Code2" Style="{StaticResource AuthEntry}"
                               MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="22" FontAttributes="Bold"
                               TextChanged="OnCodeDigitChanged"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Border x:Name="CodeBorder3" Style="{StaticResource AuthEntryBorder}"
                            WidthRequest="51" HeightRequest="56"
                            Padding="0">
                        <Entry x:Name="Code3" Style="{StaticResource AuthEntry}"
                               MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="22" FontAttributes="Bold"
                               TextChanged="OnCodeDigitChanged"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Border x:Name="CodeBorder4" Style="{StaticResource AuthEntryBorder}"
                            WidthRequest="51" HeightRequest="56"
                            Padding="0">
                        <Entry x:Name="Code4" Style="{StaticResource AuthEntry}"
                               MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="22" FontAttributes="Bold"
                               TextChanged="OnCodeDigitChanged"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Border x:Name="CodeBorder5" Style="{StaticResource AuthEntryBorder}"
                            WidthRequest="51" HeightRequest="56"
                            Padding="0">
                        <Entry x:Name="Code5" Style="{StaticResource AuthEntry}"
                               MaxLength="1" Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="22" FontAttributes="Bold"
                               TextChanged="OnCodeDigitChanged"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                </HorizontalStackLayout>

                <!-- Verify Code button -->
                <Button x:Name="VerifyBtn"
                        Text="Verify Code"
                        Style="{StaticResource AuthGradientButton}"
                        HorizontalOptions="Fill"
                        Margin="17,28,17,0"
                        Clicked="OnVerifyClicked"/>

                <!-- Resend -->
                <Label Text="Didn't received a code?"
                       Style="{StaticResource Body2}"
                       TextColor="{StaticResource HeadingText}"
                       HorizontalTextAlignment="Center"
                       Margin="0,20,0,4"/>

                <Label Text="Resend a code"
                       FontFamily="Quicksand"
                       FontAttributes="Bold"
                       FontSize="16"
                       TextColor="{StaticResource Primary}"
                       HorizontalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnResendTapped"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>