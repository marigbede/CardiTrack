<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardiTrack.Mobile.CreateAccountPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource White}">

    <ScrollView>
        <Grid RowDefinitions="Auto,*">

            <!-- ════════════════════════════════════════
                 GRADIENT HEADER (≈202px)
                 ════════════════════════════════════════ -->
            <Grid Grid.Row="0" HeightRequest="210" HorizontalOptions="Fill">
                <Image Source="gradient_auth_header.svg"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />
                <VerticalStackLayout Padding="20,48,20,0"
                                     Spacing="4"
                                     VerticalOptions="Start">
                    <Label Text="Create Account"
                           Style="{StaticResource Heading1White}" />

                    <Label Text="Step 1 of 4"
                           Style="{StaticResource Body1SemiBold}" />

                    <!-- Progress bar -->
                    <Grid Margin="0,12,0,0" HeightRequest="8"
                          HorizontalOptions="Fill">
                        <Border BackgroundColor="{StaticResource White}"
                                StrokeThickness="0"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                        </Border>
                        <Border BackgroundColor="Transparent"
                                Background="{StaticResource GradientButtonBrush}"
                                StrokeThickness="0"
                                HorizontalOptions="Start"
                                VerticalOptions="Fill"
                                WidthRequest="100">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>

            <!-- ════════════════════════════════════════
                 WHITE CARD FORM
                 ════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Margin="0,-30,0,0"
                    Padding="20,20,20,36">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30,30,0,0"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="6">

                    <!-- ── Error banner (hidden by default) ── -->
                    <Border x:Name="ErrorBanner"
                            IsVisible="False"
                            BackgroundColor="#FFF0F0"
                            StrokeThickness="0"
                            Padding="16,12"
                            Margin="0,0,0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="ErrorBannerTitle"
                                   Text="Email already registered"
                                   TextColor="{StaticResource ErrorRed}"
                                   FontFamily="Quicksand" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="Please use a different email or sign in to your account."
                                   Style="{StaticResource Body2}"
                                   TextColor="{StaticResource HeadingText}"/>
                            <Label Text="Sign in"
                                   TextColor="{StaticResource Primary}"
                                   FontFamily="Quicksand" FontAttributes="Bold" FontSize="14"
                                   Padding="0,4">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSignInTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Full Name -->
                    <Label Text="Full Name" Style="{StaticResource AuthFieldLabel}"/>
                    <Border x:Name="NameBorder" Style="{StaticResource AuthEntryBorder}">
                        <Entry x:Name="NameEntry"
                               Style="{StaticResource AuthEntry}"
                               Placeholder="Your Name"
                               ReturnType="Next"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Label x:Name="NameError" Style="{StaticResource AuthErrorLabel}" IsVisible="False"/>

                    <!-- Email Address -->
                    <Label Text="Email Address" Style="{StaticResource AuthFieldLabel}" Margin="0,8,0,2"/>
                    <Border x:Name="EmailBorder" Style="{StaticResource AuthEntryBorder}">
                        <Entry x:Name="EmailEntry"
                               Style="{StaticResource AuthEntry}"
                               Placeholder="Your email"
                               Keyboard="Email"
                               ReturnType="Next"
                               Focused="OnEntryFocused"
                               Unfocused="OnEntryUnfocused"/>
                    </Border>
                    <Label x:Name="EmailError" Style="{StaticResource AuthErrorLabel}" IsVisible="False"/>

                    <!-- Password -->
                    <Label Text="Password" Style="{StaticResource AuthFieldLabel}" Margin="0,8,0,2"/>
                    <Border x:Name="PasswordBorder" Style="{StaticResource AuthEntryBorder}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="PasswordEntry"
                                   Grid.Column="0"
                                   Style="{StaticResource AuthEntry}"
                                   Placeholder="At least 8 characters"
                                   IsPassword="True"
                                   ReturnType="Next"
                                   TextChanged="OnPasswordTextChanged"
                                   Focused="OnEntryFocused"
                                   Unfocused="OnEntryUnfocused"/>
                            <ImageButton x:Name="PasswordToggle"
                                         Grid.Column="1"
                                         Source="icon_eye_off.svg"
                                         WidthRequest="24" HeightRequest="24"
                                         BackgroundColor="Transparent"
                                         VerticalOptions="Center"
                                         Margin="0,0,4,0"
                                         Clicked="OnPasswordToggleClicked"/>
                        </Grid>
                    </Border>

                    <!-- Password strength indicator -->
                    <Grid ColumnDefinitions="*,4,*,4,*,4,*"
                          HeightRequest="6" Margin="0,4,0,0">
                        <BoxView x:Name="Str0" Grid.Column="0" CornerRadius="3"
                                 Color="{StaticResource Divider}"/>
                        <BoxView x:Name="Str1" Grid.Column="2" CornerRadius="3"
                                 Color="{StaticResource Divider}"/>
                        <BoxView x:Name="Str2" Grid.Column="4" CornerRadius="3"
                                 Color="{StaticResource Divider}"/>
                        <BoxView x:Name="Str3" Grid.Column="6" CornerRadius="3"
                                 Color="{StaticResource Divider}"/>
                    </Grid>
                    <Label x:Name="StrengthLabel"
                           Style="{StaticResource Body2}"
                           FontSize="12" Margin="0,0,0,0"/>

                    <!-- Confirm Password -->
                    <Label Text="Confirm Password" Style="{StaticResource AuthFieldLabel}" Margin="0,8,0,2"/>
                    <Border x:Name="ConfirmBorder" Style="{StaticResource AuthEntryBorder}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="ConfirmEntry"
                                   Grid.Column="0"
                                   Style="{StaticResource AuthEntry}"
                                   Placeholder="Re-enter password"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   Focused="OnEntryFocused"
                                   Unfocused="OnEntryUnfocused"/>
                            <ImageButton x:Name="ConfirmToggle"
                                         Grid.Column="1"
                                         Source="icon_eye_off.svg"
                                         WidthRequest="24" HeightRequest="24"
                                         BackgroundColor="Transparent"
                                         VerticalOptions="Center"
                                         Margin="0,0,4,0"
                                         Clicked="OnConfirmToggleClicked"/>
                        </Grid>
                    </Border>
                    <Label x:Name="ConfirmError" Style="{StaticResource AuthErrorLabel}" IsVisible="False"/>

                    <!-- Terms checkbox -->
                    <HorizontalStackLayout Spacing="4" Margin="0,10,0,0">
                        <CheckBox x:Name="TermsCheck"
                                  Color="{StaticResource Primary}"
                                  WidthRequest="24" HeightRequest="24"
                                  VerticalOptions="Center"/>
                        <Label VerticalTextAlignment="Center" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="I agree to the "
                                          FontFamily="Quicksand" FontSize="14"
                                          TextColor="{StaticResource BodyText}"/>
                                    <Span Text="Terms of Service"
                                          FontFamily="Quicksand" FontSize="14"
                                          TextColor="{StaticResource Primary}"/>
                                    <Span Text=" and "
                                          FontFamily="Quicksand" FontSize="14"
                                          TextColor="{StaticResource BodyText}"/>
                                    <Span Text="Privacy Policy"
                                          FontFamily="Quicksand" FontSize="14"
                                          TextColor="{StaticResource Primary}"/>
                                    <Span Text="."
                                          FontFamily="Quicksand" FontSize="14"
                                          TextColor="{StaticResource BodyText}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Create Account button -->
                    <Button x:Name="CreateBtn"
                            Text="Create Account"
                            Style="{StaticResource AuthGradientButton}"
                            HorizontalOptions="Fill"
                            Margin="0,16,0,0"
                            Clicked="OnCreateAccountClicked"/>

                    <!-- Divider -->
                    <Grid ColumnDefinitions="*,Auto,*"
                          Margin="0,12,0,12">
                        <BoxView Grid.Column="0" Style="{StaticResource DividerLine}"/>
                        <Label Grid.Column="1"
                               Text="Or continue with"
                               Style="{StaticResource Body2}"
                               TextColor="{StaticResource MutedText}"
                               Margin="16,0"/>
                        <BoxView Grid.Column="2" Style="{StaticResource DividerLine}"/>
                    </Grid>

                    <!-- Social login buttons -->
                    <Grid ColumnDefinitions="*,12,*">
                        <Border Grid.Column="0" Style="{StaticResource GoogleButton}">
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   Spacing="8">
                                <Image Source="google_icon.svg"
                                       WidthRequest="22" HeightRequest="22"
                                       VerticalOptions="Center"/>
                                <Label Text="Google" FontFamily="Quicksand" FontAttributes="Bold"
                                       FontSize="18" TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource AppleButton}">
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   Spacing="8">
                                <Image Source="apple_icon.svg"
                                       WidthRequest="22" HeightRequest="22"
                                       VerticalOptions="Center"/>
                                <Label Text="Apple" FontFamily="Quicksand" FontAttributes="Bold"
                                       FontSize="18" TextColor="{StaticResource White}"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Sign-in link -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Margin="0,24,0,0"
                                           Spacing="2">
                        <Label Text="Already have an account"
                               Style="{StaticResource Body2}"
                               VerticalTextAlignment="Center"/>
                        <Label Text="Sign In"
                               Style="{StaticResource PrimaryLink}"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSignInTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>