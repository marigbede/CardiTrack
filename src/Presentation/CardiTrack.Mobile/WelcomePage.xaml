<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="RootPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CardiTrack.Mobile"
             x:Class="CardiTrack.Mobile.WelcomePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource White}">

    <Grid RowDefinitions="*,Auto">

        <!-- ── Carousel (hero + text) ── -->
        <CarouselView x:Name="SlideCarousel"
                      Grid.Row="0"
                      ItemsSource="{Binding Source={x:Reference RootPage}, Path=Slides}"
                      Loop="False"
                      IsScrollAnimated="True">
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="local:WelcomeSlide">
                    <Grid RowDefinitions="Auto,Auto,Auto,*">

                        <!-- Hero image: full-bleed with wave overlay -->
                        <Grid Grid.Row="0" HeightRequest="571"
                              HorizontalOptions="Fill">
                            <Image Source="{Binding HeroImage}"
                                   Aspect="AspectFill"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill" />
                            <Image Source="wave_overlay.svg"
                                   Aspect="Fill"
                                   HeightRequest="120"
                                   VerticalOptions="End"
                                   HorizontalOptions="Fill"
                                   InputTransparent="True"/>
                        </Grid>

                        <!-- Title -->
                        <Label Grid.Row="1"
                               Text="{Binding Title}"
                               Style="{StaticResource Heading1}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               Margin="24,8,24,0" />

                        <!-- Subtitle -->
                        <Label Grid.Row="2"
                               Text="{Binding Subtitle}"
                               Style="{StaticResource BodySubtitle}"
                               Margin="40,12,40,0" />
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- ── Header overlay (logo + sign-up, on top of hero) ── -->
        <Grid Grid.Row="0"
              Padding="20,55,20,0"
              ColumnDefinitions="Auto,*"
              VerticalOptions="Start"
              InputTransparent="False">

            <!-- Logo icon -->
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource White}"
                    WidthRequest="46" HeightRequest="46"
                    StrokeThickness="0"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="9"/>
                </Border.StrokeShape>
                <Image Source="carditrack_logo.svg"
                       WidthRequest="37" HeightRequest="32"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Sign up link -->
            <Label Grid.Column="1"
                   Text="Sign up"
                   FontFamily="Quicksand"
                   FontAttributes="Bold"
                   FontSize="16"
                   TextColor="{StaticResource White}"
                   TextDecorations="Underline"
                   HorizontalOptions="End"
                   VerticalOptions="Start"
                   Padding="0,8,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSignUpTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- ── Bottom area ── -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="10"
                             Padding="20,4,20,28">

            <!-- Custom pill indicators -->
            <HorizontalStackLayout x:Name="IndicatorPanel"
                                   HorizontalOptions="Center"
                                   Spacing="8">
                <BoxView x:Name="Ind0" WidthRequest="32" HeightRequest="8"
                         CornerRadius="4" Color="{StaticResource ActiveIndicator}"/>
                <BoxView x:Name="Ind1" WidthRequest="8" HeightRequest="8"
                         CornerRadius="4" Color="{StaticResource InactiveIndicator}"/>
                <BoxView x:Name="Ind2" WidthRequest="8" HeightRequest="8"
                         CornerRadius="4" Color="{StaticResource InactiveIndicator}"/>
            </HorizontalStackLayout>

            <!-- CTA button (hidden on slide 0) -->
            <Button x:Name="CtaButton"
                    Text="Start Free 30-Day Trial"
                    Style="{StaticResource PrimaryGradientButton}"
                    IsVisible="False"
                    HorizontalOptions="Fill"
                    Margin="0,6,0,0"
                    Clicked="OnCtaClicked" />

            <!-- Pricing disclaimer -->
            <Label Text="Then $8/month - Cancel anytime"
                   Style="{StaticResource Body2}"
                   HorizontalTextAlignment="Center" />

            <!-- Terms & Privacy -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                <Label Text="By continuing, you agree to "
                       Style="{StaticResource Body2}"
                       VerticalTextAlignment="Center" />
                <Label Text="Terms &amp; Privacy"
                       TextColor="{StaticResource Primary}"
                       FontFamily="Quicksand"
                       FontAttributes="Bold"
                       FontSize="14"
                       TextDecorations="Underline"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTermsTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>