<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ════════════════════════════════════════════
         DEFAULT CONTROL STYLES (Quicksand base)
         ════════════════════════════════════════════ -->

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{StaticResource InactiveIndicator}"/>
        <Setter Property="SelectedIndicatorColor" Value="{StaticResource ActiveIndicator}"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
        <Setter Property="StrokeShape" Value="Rectangle"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource Gray500}" />
                            <Setter Property="BackgroundColor" Value="{StaticResource Gray200}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Primary}" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="{StaticResource BodyText}" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="Quicksand" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Gray500}" />
        <Setter Property="FontFamily" Value="Quicksand" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource HeadingText}, Dark={StaticResource White}}" />
    </Style>

    <!-- ════════════════════════════════════════════
         NAMED TYPOGRAPHY STYLES  (Figma tokens)
         ════════════════════════════════════════════ -->

    <Style x:Key="Heading1" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
    </Style>

    <Style x:Key="Heading1White" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
    </Style>

    <Style x:Key="Heading2" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
    </Style>

    <Style x:Key="Heading3" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
    </Style>

    <Style x:Key="Body1SemiBold" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
    </Style>

    <Style x:Key="Body1SemiBoldDark" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
    </Style>

    <Style x:Key="Body2Medium" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
    </Style>

    <Style x:Key="Body2" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource BodyText}"/>
    </Style>

    <Style x:Key="BodySubtitle" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource BodyText}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="WordWrap"/>
    </Style>

    <!-- ════════════════════════════════════════════
         NAMED BUTTON STYLES
         ════════════════════════════════════════════ -->

    <Style x:Key="PrimaryGradientButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GradientButtonBrush}"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="CornerRadius" Value="25"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style x:Key="AuthGradientButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GradientButtonLightBrush}"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="CornerRadius" Value="25"/>
        <Setter Property="HeightRequest" Value="53"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style x:Key="SecondaryOutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="CornerRadius" Value="25"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="BorderColor" Value="{StaticResource PrimaryDark}"/>
        <Setter Property="BorderWidth" Value="1"/>
        <Setter Property="Padding" Value="24,0"/>
    </Style>

    <Style x:Key="GoogleButton" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="Stroke" Value="{StaticResource Primary}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="25"/>
        </Setter>
    </Style>

    <Style x:Key="AppleButton" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Black}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="25"/>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════
         AUTH FORM STYLES
         ════════════════════════════════════════════ -->

    <Style x:Key="AuthFieldLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="AuthEntryBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}"/>
        <Setter Property="Stroke" Value="{StaticResource InputBorder}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="Padding" Value="16,4"/>
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="10"/>
        </Setter>
    </Style>

    <Style x:Key="AuthEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource BodyText}"/>
        <Setter Property="TextColor" Value="{StaticResource HeadingText}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style x:Key="AuthErrorLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource ErrorRed}"/>
    </Style>

    <Style x:Key="PrimaryLink" TargetType="Label">
        <Setter Property="FontFamily" Value="Quicksand"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        <Setter Property="TextDecorations" Value="Underline"/>
    </Style>

    <Style x:Key="DividerLine" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Divider}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

</ResourceDictionary>