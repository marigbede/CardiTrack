{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CardiTrack;Integrated Security=true;TrustServerCertificate=True",
    "Redis": "localhost:6379"
  },
  "Auth0": {
    "Domain": "YOUR_AUTH0_DOMAIN.us.auth0.com",
    "Audience": "https://api.carditrack.com",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET",
    "CallbackUrl": "https://localhost:7001/api/auth/callback",
    "LogoutUrl": "https://localhost:7001/"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7002",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "SeqUrl": "http://localhost:5341"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },
  "Encryption": {
    "Key": "GENERATE_32_BYTE_ENCRYPTION_KEY_HERE_REPLACE_WITH_SECURE_KEY",
    "IV": "GENERATE_16_BYTE_IV_HERE"
  },
  "DeviceProviders": [
    {
      "Provider": "Fitbit",
      "ClientId": "YOUR_FITBIT_CLIENT_ID",
      "ClientSecret": "YOUR_FITBIT_CLIENT_SECRET",
      "AuthorizationUrl": "https://www.fitbit.com/oauth2/authorize",
      "TokenUrl": "https://api.fitbit.com/oauth2/token",
      "ApiBaseUrl": "https://api.fitbit.com",
      "Scopes": [ "activity", "heartrate", "sleep", "profile" ],
      "RedirectUri": "https://localhost:7001/api/oauth/callback/fitbit",
      "TokenLifetimeHours": 8
    },
    {
      "Provider": "Garmin",
      "ClientId": "YOUR_GARMIN_CLIENT_ID",
      "ClientSecret": "YOUR_GARMIN_CLIENT_SECRET",
      "AuthorizationUrl": "https://connect.garmin.com/oauthConfirm",
      "TokenUrl": "https://connectapi.garmin.com/oauth-service/oauth/token",
      "ApiBaseUrl": "https://apis.garmin.com",
      "Scopes": [ "HEALTH_API" ],
      "RedirectUri": "https://localhost:7001/api/oauth/callback/garmin",
      "TokenLifetimeHours": 3600
    },
    {
      "Provider": "Withings",
      "ClientId": "YOUR_WITHINGS_CLIENT_ID",
      "ClientSecret": "YOUR_WITHINGS_CLIENT_SECRET",
      "AuthorizationUrl": "https://account.withings.com/oauth2_user/authorize2",
      "TokenUrl": "https://wbsapi.withings.net/v2/oauth2",
      "ApiBaseUrl": "https://wbsapi.withings.net",
      "Scopes": [ "user.metrics", "user.activity" ],
      "RedirectUri": "https://localhost:7001/api/oauth/callback/withings",
      "TokenLifetimeHours": 3
    },
    {
      "Provider": "Oura",
      "ClientId": "YOUR_OURA_CLIENT_ID",
      "ClientSecret": "YOUR_OURA_CLIENT_SECRET",
      "AuthorizationUrl": "https://cloud.ouraring.com/oauth/authorize",
      "TokenUrl": "https://api.ouraring.com/oauth/token",
      "ApiBaseUrl": "https://api.ouraring.com",
      "Scopes": [ "daily", "heartrate", "sleep" ],
      "RedirectUri": "https://localhost:7001/api/oauth/callback/oura",
      "TokenLifetimeHours": 24
    },
    {
      "Provider": "Whoop",
      "ClientId": "YOUR_WHOOP_CLIENT_ID",
      "ClientSecret": "YOUR_WHOOP_CLIENT_SECRET",
      "AuthorizationUrl": "https://api.prod.whoop.com/oauth/oauth2/auth",
      "TokenUrl": "https://api.prod.whoop.com/oauth/oauth2/token",
      "ApiBaseUrl": "https://api.prod.whoop.com",
      "Scopes": [ "read:recovery", "read:cycles", "read:sleep", "read:body_measurement" ],
      "RedirectUri": "https://localhost:7001/api/oauth/callback/whoop",
      "TokenLifetimeHours": 24
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
