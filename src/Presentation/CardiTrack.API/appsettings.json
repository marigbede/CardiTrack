{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CardiTrack;Integrated Security=true;TrustServerCertificate=True",
    "Redis": "localhost:6379"
  },
  "Auth0": {
    "Domain": "YOUR_AUTH0_DOMAIN.us.auth0.com",
    "Audience": "https://api.carditrack.com",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET",
    "CallbackUrl": "https://localhost:7001/api/auth/callback",
    "LogoutUrl": "https://localhost:7001/"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7002",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "SeqUrl": "http://localhost:5341"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },
  "Encryption": {
    "Key": "GENERATE_32_BYTE_ENCRYPTION_KEY_HERE_REPLACE_WITH_SECURE_KEY",
    "IV": "GENERATE_16_BYTE_IV_HERE"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
